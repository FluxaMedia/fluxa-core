# Trakt — https://trakt.tv/oauth/applications
# Set redirect URI to: http://127.0.0.1:1430/oauth/trakt  (dev)
FLUXA_TRAKT_CLIENT_ID=your_trakt_client_id
FLUXA_TRAKT_CLIENT_SECRET=your_trakt_client_secret

# Simkl — https://simkl.com/settings/developer/
# Set redirect URI to: http://127.0.0.1:1430/oauth/simkl  (dev)
FLUXA_SIMKL_CLIENT_ID=your_simkl_client_id
FLUXA_SIMKL_CLIENT_SECRET=your_simkl_client_secret

# MyAnimeList — https://myanimelist.net/apiconfig
# Set redirect URI to: http://127.0.0.1:1430/oauth/mal  (dev)
FLUXA_MAL_CLIENT_ID=your_mal_client_id

# Optional: restrict which web origins can reach the companion (comma-separated).
# Defaults to localhost if unset.
# FLUXA_WEB_ORIGIN=http://localhost:1430,https://your-deployed-app.example.com

# Optional: shared bearer token the web client must send. Leave unset for local dev.
# FLUXA_COMPANION_TOKEN=your_random_token
